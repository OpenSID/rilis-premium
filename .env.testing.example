# Template environment untuk menjalankan test (PHPUnit).
#
# Salin file ini menjadi `.env.testing` lalu sesuaikan koneksi database mesin Anda:
#
#   cp .env.testing.example .env.testing
#
# Laravel memuat `.env.testing` otomatis saat APP_ENV=testing (di-set oleh phpunit.xml.dist),
# baik melalui `php artisan test` maupun `vendor/bin/phpunit`.
#
# File `.env.testing` di-gitignore — JANGAN di-commit. Hanya template ini yang dilacak.

# Koneksi database test (spesifik mesin) — bagian inilah yang biasanya perlu disesuaikan.
DB_CONNECTION=default
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=

# Contoh untuk MAMP:
# DB_PORT=8889
# DB_USERNAME=root
# DB_PASSWORD=root

# Catatan:
# - Nama database test (DB_DATABASE) sudah di-set di phpunit.xml.dist (opensid-laravel-test)
#   karena nilainya sama di semua mesin. Tidak perlu ditaruh di sini.
# - TIDAK perlu lagi menyalin/mengedit phpunit.xml, dan TIDAK perlu mengaktifkan demo_mode
#   atau menyetel desa/app_key. Lihat documents/panduan-menjalankan-test.md.