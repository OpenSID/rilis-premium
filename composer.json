{
    "name": "opendesa/opensid",
    "description": "OpenSID adalah Sistem Informasi Desa (SID) yang sengaja dirancang supaya terbuka dan dapat dikembangkan bersama-sama oleh komunitas peduli SID. OpenSID awalnya dikembangkan menggunakan SID dari Combine Resource Institution (CRI). SID CRI terakhir yang telah digabung dengan OpenSID adalah SID 3.10 yang diperoleh dari teman-teman di https://www.facebook.com/groups/komunitasopendesa pada tanggal 15 Pebruari 2017.",
    "license": "GPL-3.0-or-later",
    "type": "project",
    "keywords": [
        "opensid",
        "sistem-informasi-desa"
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/OpenSID/laravel-eloquent-query-cache"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-fileinfo": "*",
        "codeigniter/framework": "^3.1",
        "cviebrock/eloquent-sluggable": "^13.0",
        "dg/mysql-dump": "^1.6",
        "doctrine/dbal": "^4.0",
        "edwinhoksberg/php-fcm": "^1.2",
        "erusev/parsedown": "^1.7",
        "f9webltd/laravel-api-response-helpers": "^3.1",
        "google/apiclient": "^2.11",
        "guzzlehttp/guzzle": "^7.2",
        "karriere/pdf-merge": "^2.1",
        "laravel-notification-channels/telegram": "^7.0",
        "laravel/framework": "^13.8",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "mike42/escpos-php": "^3.0",
        "opensid/router": "^2403",
        "openspout/openspout": "^4.25",
        "ramsey/uuid": "^4.9",
        "rap2hpoutre/fast-excel": "^5.6",
        "rennokki/laravel-eloquent-query-cache": "dev-laravel-13",
        "slowprog/composer-copy-file": "^0.3.3",
        "spatie/eloquent-sortable": "^5.0",
        "spatie/image": "^3.0",
        "spatie/laravel-activitylog": "^4.10",
        "spatie/laravel-fractal": "^6.4",
        "spatie/laravel-json-api-paginate": "^2.0",
        "spatie/laravel-one-time-passwords": "^1.1",
        "spatie/laravel-query-builder": "^7.3",
        "spipu/html2pdf": "^5.3",
        "stechstudio/laravel-zipstream": "^5.7",
        "tinymce/tinymce": "^7.2",
        "voku/anti-xss": "^4.1",
        "yajra/laravel-datatables-oracle": "^13.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "ergebnis/composer-normalize": "^2.42",
        "fakerphp/faker": "^1.23",
        "friendsofphp/php-cs-fixer": "^3.49",
        "fruitcake/laravel-debugbar": "^4.3",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.63",
        "mikey179/vfsstream": "~1.1.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12",
        "rector/rector": "^2.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "app/database/factories/",
            "Database\\Seeders\\": "app/database/seeders/",
            "Modules\\": "Modules/"
        },
        "exclude-from-classmap": [
            "Modules/*/Http/Controllers",
            "tests/Feature/Perbaiki/",
            "tests/Unit/Perbaiki/"
        ],
        "files": [
            "app/Helpers/core_helper.php",
            "app/Helpers/donjolib_helper.php",
            "app/Helpers/general_helper.php",
            "app/Helpers/opensid_helper.php",
            "app/Helpers/pict_helper.php",
            "app/Helpers/theme_helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "composer-normalize": {
            "indent-size": 4,
            "indent-style": "space"
        },
        "copy-file": {
            "vendor/tinymce/tinymce": "assets/js/tinymce-72",
            "storage/app/vendor": "vendor",
            "storage/app/public/assets/js/tinymce-72/plugins/image": "assets/js/tinymce-72/plugins/image"
        },
        "google/apiclient-services": [
            "Drive",
            "Script"
        ]
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "post-install-cmd": [
            "SlowProg\\CopyFile\\ScriptHandler::copy"
        ],
        "pre-autoload-dump": [
            "Google\\Task\\Composer::cleanup",
            "SlowProg\\CopyFile\\ScriptHandler::copy"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "SlowProg\\CopyFile\\ScriptHandler::copy",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test"
        ],
        "blade": [
            "npm run prettier-blade"
        ],
        "fixer": [
            "php-cs-fixer fix --allow-risky=yes"
        ],
        "rector": [
            "rector process --ansi"
        ]
    }
}
